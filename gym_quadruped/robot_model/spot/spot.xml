<mujoco model="spot">
  <compiler angle="radian"/>

  <option integrator="implicitfast" cone="elliptic" impratio="100"/>

  <visual>
    <global ellipsoidinertia="true"/>
  </visual>

  <asset>
    <material name="BlackAbs" rgba="0.1 0.1 0.1 1"/>
    <material name="wrap" rgba="0.878431 0.666666 0.227450 1"/>

    <mesh file="assets/body_0.obj"/>
    <mesh file="assets/body_1.obj"/>
    <mesh file="assets/front_left_hip.obj"/>
    <mesh file="assets/front_left_upper_leg_0.obj"/>
    <mesh file="assets/front_left_upper_leg_1.obj"/>
    <mesh file="assets/front_left_lower_leg.obj"/>
    <mesh file="assets/front_right_hip.obj"/>
    <mesh file="assets/front_right_upper_leg_0.obj"/>
    <mesh file="assets/front_right_upper_leg_1.obj"/>
    <mesh file="assets/front_right_lower_leg.obj"/>
    <mesh file="assets/rear_left_hip.obj"/>
    <mesh file="assets/rear_left_upper_leg_0.obj"/>
    <mesh file="assets/rear_left_upper_leg_1.obj"/>
    <mesh file="assets/rear_left_lower_leg.obj"/>
    <mesh file="assets/rear_right_hip.obj"/>
    <mesh file="assets/rear_right_upper_leg_0.obj"/>
    <mesh file="assets/rear_right_upper_leg_1.obj"/>
    <mesh file="assets/rear_right_lower_leg.obj"/>
    <mesh file="assets/body_collision.obj"/>
    <mesh file="assets/left_upper_leg_collision.obj"/>
    <mesh file="assets/left_lower_leg_collision.obj"/>
    <mesh file="assets/right_upper_leg_collision.obj"/>
    <mesh file="assets/right_lower_leg_collision.obj"/>
  </asset>

  <default>

    <default class="spot">
      <geom solref="0.004 1"/>
      <default class="visual">
        <geom group="2" type="mesh" contype="0" conaffinity="0"/>
      </default>
      <default class="collision">
        <geom group="3" type="mesh"/>
        <default class="foot">
          <geom type="sphere" size="0.036" pos="0 0 -0.3365" priority="1" condim="6" solimp="0.015 1 0.036"
            friction="0.8 0.02 0.01"/>
        </default>
      </default>
    </default>

    <joint damping="0.6" armature="0.01" frictionloss="0.2"/>

    <default class="hip">
        <motor ctrlrange="-144.4 144.4"/>
    </default>
    <default class="thigh">
        <motor ctrlrange="-135.278 135.278"/>
    </default>
    <default class="calf">
        <motor ctrlrange="-135.278 135.278"/>
    </default>
  </default>

  <worldbody>
    <light name="spotlight" mode="targetbodycom" target="body" pos="3 0 4" cutoff="30"/>
    <body name="body" childclass="spot" pos="0 0 .75">
      <light name="tracking" mode="trackcom" pos="0 0 2"/>
      <freejoint name="freejoint"/>
      <inertial pos="0.0063944 -9.81216e-05 0.000911379" mass="32.86" diaginertia="0.13144 0.13144 0.13144"/>
      <geom mesh="body_0" material="BlackAbs" class="visual"/>
      <geom mesh="body_1" material="wrap" class="visual"/>
      <geom mesh="body_collision" class="collision"/>
      
      <body name="FL_hip" pos="0.29785 0.055 0">
        <inertial pos="-0.00537435 0.0128418 9.87523e-05" quat="1 1 -1 1" mass="1.68"
          diaginertia="0.00226544 0.00211474 0.00181296"/>
        <joint name="FL_hip_joint" axis="1 0 0" range="-0.785398 0.785398"/>
        <geom material="BlackAbs" mesh="front_left_hip" class="visual"/>
        
        <body name="FL_thigh" pos="0 0.1108 0">
          <inertial pos="0.00514237 -0.00243237 -0.121009" mass="2.34" diaginertia="0.0275596 0.0273549 0.00284815"/>
          <joint name="FL_thigh_joint" axis="0 1 0" range="-0.898845 2.29511"/>
          <geom mesh="front_left_upper_leg_0" material="wrap" class="visual"/>
          <geom mesh="front_left_upper_leg_1" material="BlackAbs" class="visual"/>
          <geom mesh="left_upper_leg_collision" class="collision"/>
          
          <body name="FL_calf" pos="0.025 0 -0.32">
            <inertial pos="0.00225794 4.6076e-05 -0.180082" quat="1 0 0 1" mass="0.35"
              diaginertia="0.00405032 0.00399902 0.00014934"/>
            <joint name="FL_calf_joint" axis="0 1 0" range="-2.7929 -0.254402"/>
            <geom material="BlackAbs" mesh="front_left_lower_leg" class="visual"/>
            <geom mesh="left_lower_leg_collision" class="collision"/>
            <geom name="FL" class="foot"/>
          </body>
        </body>
      </body>

      <body name="FR_hip" pos="0.29785 -0.055 0">
        <inertial pos="-0.00537435 -0.0128418 -9.87523e-05" quat="1 1 -1 1" mass="1.68"
          diaginertia="0.00226544 0.00211474 0.00181296"/>
        <joint name="FR_hip_joint" axis="1 0 0" range="-0.785398 0.785398"/>
        <geom material="BlackAbs" mesh="front_right_hip" class="visual"/>
        
        <body name="FR_thigh" pos="0 -0.1108 0">
          <inertial pos="0.00514237 0.00243237 -0.121009" mass="2.34" diaginertia="0.0275596 0.0273549 0.00284815"/>
          <joint name="FR_thigh_joint" axis="0 1 0" range="-0.898845 2.24363"/>
          <geom mesh="front_right_upper_leg_0" material="wrap" class="visual"/>
          <geom mesh="front_right_upper_leg_1" material="BlackAbs" class="visual"/>
          <geom mesh="right_upper_leg_collision" class="collision"/>
          
          <body name="FR_calf" pos="0.025 0 -0.32">
            <inertial pos="0.00225794 4.6076e-05 -0.180082" quat="1 0 0 1" mass="0.35"
              diaginertia="0.00405032 0.00399902 0.00014934"/>
            <joint name="FR_calf_joint" axis="0 1 0" range="-2.7929 -0.255648"/>
            <geom material="BlackAbs" mesh="front_right_lower_leg" class="visual"/>
            <geom mesh="right_lower_leg_collision" class="collision"/>
            <geom name="FR" class="foot"/>
          </body>
        </body>
      </body>

      <body name="RL_hip" pos="-0.29785 0.055 0">
        <inertial pos="0.00537435 0.0128418 -9.87523e-05" quat="1 1 -1 1" mass="1.68"
          diaginertia="0.00226544 0.00211474 0.00181296"/>
        <joint name="RL_hip_joint" axis="1 0 0" range="-0.785398 0.785398"/>
        <geom material="BlackAbs" mesh="rear_left_hip" class="visual"/>
        
        <body name="RL_thigh" pos="0 0.1108 0">
          <inertial pos="0.00514237 -0.00243237 -0.121009" mass="2.34" diaginertia="0.0275596 0.0273549 0.00284815"/>
          <joint name="RL_thigh_joint" axis="0 1 0" range="-0.898845 2.29511"/>
          <geom mesh="rear_left_upper_leg_0" material="wrap" class="visual"/>
          <geom mesh="rear_left_upper_leg_1" material="BlackAbs" class="visual"/>
          <geom mesh="left_upper_leg_collision" class="collision"/>
          
          <body name="RL_calf" pos="0.025 0 -0.32">
            <inertial pos="0.00225794 4.6076e-05 -0.180082" quat="1 0 0 1" mass="0.35"
              diaginertia="0.00405032 0.00399902 0.00014934"/>
            <joint name="RL_calf_joint" axis="0 1 0" range="-2.7929 -0.247067"/>
            <geom material="BlackAbs" mesh="rear_left_lower_leg" class="visual"/>
            <geom mesh="left_lower_leg_collision" class="collision"/>
            <geom name="RL" class="foot"/>
          </body>
        </body>
      </body>

      <body name="RR_hip" pos="-0.29785 -0.055 0">
        <inertial pos="0.00537435 -0.0128418 9.87523e-05" quat="1 1 -1 1" mass="1.68"
          diaginertia="0.00226544 0.00211474 0.00181296"/>
        <joint name="RR_hip_joint" axis="1 0 0" range="-0.785398 0.785398"/>
        <geom material="BlackAbs" mesh="rear_right_hip" class="visual"/>
        
        <body name="RR_thigh" pos="0 -0.1108 0">
          <inertial pos="0.00514237 0.00243237 -0.121009" mass="2.34" diaginertia="0.0275596 0.0273549 0.00284815"/>
          <joint name="RR_thigh_joint" axis="0 1 0" range="-0.898845 2.29511"/>
          <geom mesh="rear_right_upper_leg_0" material="wrap" class="visual"/>
          <geom mesh="rear_right_upper_leg_1" material="BlackAbs" class="visual"/>
          <geom mesh="right_upper_leg_collision" class="collision"/>
          
          <body name="RR_calf" pos="0.025 0 -0.32">
            <inertial pos="0.00225794 4.6076e-05 -0.180082" quat="1 0 0 1" mass="0.35"
              diaginertia="0.00405032 0.00399902 0.00014934"/>
            <joint name="RR_calf_joint" axis="0 1 0" range="-2.7929 -0.248282"/>
            <geom material="BlackAbs" mesh="rear_left_lower_leg" class="visual"/>
            <geom mesh="right_lower_leg_collision" class="collision"/>
            <geom name="RR" class="foot"/>
          </body>
        </body>
      </body>
      
    </body>
  </worldbody>

  <contact>
    <exclude body1="body" body2="FL_calf"/>
    <exclude body1="body" body2="FR_calf"/>
    <exclude body1="body" body2="RL_calf"/>
    <exclude body1="body" body2="RR_calf"/>
    <exclude body1="body" body2="FL_thigh"/>
    <exclude body1="body" body2="FR_thigh"/>
    <exclude body1="body" body2="RL_thigh"/>
    <exclude body1="body" body2="RR_thigh"/>
    <exclude body1="body" body2="FL_hip"/>
    <exclude body1="body" body2="FR_hip"/>
    <exclude body1="body" body2="RL_hip"/>
    <exclude body1="body" body2="RR_hip"/>
  </contact>

  <actuator>
    <motor name="FL_hip"   class="hip"    gear="1" joint="FL_hip_joint"/>
    <motor name="FL_thigh" class="thigh"  gear="1" joint="FL_thigh_joint"/>
    <motor name="FL_calf"  class="calf"   gear="1" joint="FL_calf_joint"/>
    <motor name="FR_hip"   class="hip"    gear="1" joint="FR_hip_joint"/>
    <motor name="FR_thigh" class="thigh"  gear="1" joint="FR_thigh_joint"/>
    <motor name="FR_calf"  class="calf"   gear="1" joint="FR_calf_joint"/>
    <motor name="RL_hip"   class="hip"    gear="1" joint="RL_hip_joint"/>
    <motor name="RL_thigh" class="thigh"  gear="1" joint="RL_thigh_joint"/>
    <motor name="RL_calf"  class="calf"   gear="1" joint="RL_calf_joint"/>
    <motor name="RR_hip"   class="hip"    gear="1" joint="RR_hip_joint"/>
    <motor name="RR_thigh" class="thigh"  gear="1" joint="RR_thigh_joint"/>
    <motor name="RR_calf"  class="calf"   gear="1" joint="RR_calf_joint" />
  </actuator>

  <keyframe>
    <key name="home" qpos="
    0 0 0.46
    1 0 0 0
    0 1.04 -1.8
    0 1.04 -1.8
    0 1.04 -1.8
    0 1.04 -1.8"
      ctrl="
    0 1.04 -1.8
    0 1.04 -1.8
    0 1.04 -1.8
    0 1.04 -1.8"/>
  </keyframe>
</mujoco>
